# Required
TEAM_ID=113
TICKETMASTER_API_KEY=replace_me
MQTT_HOST=homeassistant.local
MQTT_PORT=1883
MQTT_USERNAME=replace_me
MQTT_PASSWORD=replace_me

# Common
TEAM_SLUG=
TEAM_NAME=
HOME_GAMES_ONLY=true
LOOKAHEAD_DAYS=60
POLL_INTERVAL_MINUTES=15
MATCH_CACHE_TTL_HOURS=24
TIMEZONE=America/New_York
LOG_LEVEL=INFO
DATA_DIR=./data
POST_GAME_GRACE_MINUTES=240
FAILURE_RETRY_SECONDS=30

# MQTT
MQTT_TOPIC_PREFIX=mlb_ticket_tracker
MQTT_DISCOVERY_PREFIX=homeassistant
MQTT_CLIENT_ID=mlb-ticket-tracker
MQTT_KEEPALIVE=60

# Providers
ENABLE_TICKETMASTER=true
ENABLE_SEATGEEK=false
ENABLE_VIVID=false
ENABLE_EXPERIMENTAL_ADAPTERS=false
SEATGEEK_CLIENT_ID=
VIVID_API_TOKEN=

# Runtime
DRY_RUN=false
HTTP_TIMEOUT_SECONDS=20
REQUEST_JITTER_SECONDS=5
TICKETMASTER_RATE_LIMIT_DELAY_SECONDS=0.5
SEATGEEK_RATE_LIMIT_DELAY_SECONDS=0.5
VIVID_RATE_LIMIT_DELAY_SECONDS=1.0
